COMPOSE_PROJECT_NAME=hermes

# DNS records must point to your VPS public IP before the first deploy.
HERMES_DOMAIN=hermes.solucoes-nexus.tech
WORKSPACE_DOMAIN=workspace.solucoes-nexus.tech
HERMES_API_DOMAIN=api-hermes.solucoes-nexus.tech

# Public API key used by Hermes Desktop and by Hermes Workspace internally.
API_SERVER_KEY=change-me-long-random-api-key
API_SERVER_CORS_ORIGINS=https://workspace.solucoes-nexus.tech

# Password for the Workspace web UI.
HERMES_PASSWORD=change-me-workspace-password

# Basic-auth for https://hermes.solucoes-nexus.tech dashboard.
# Generate on Linux/VPS:
#   htpasswd -nbB admin 'your-password'
# If the generated hash contains $, escape each $ as $$ in this .env file.
DASHBOARD_BASIC_AUTH=admin:change-me-bcrypt-hash

COOKIE_SECURE=1
TRUST_PROXY=1

SEARXNG_SECRET=change-me-long-random-searxng-secret

# Provider keys are not limited here. Add any provider env var supported by
# hermes-agent; env_file passes them through to the container.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
NOUS_API_KEY=
HF_TOKEN=
NOVITA_API_KEY=
MINIMAX_API_KEY=
